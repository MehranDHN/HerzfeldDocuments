@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <http://schema.org/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mdhn: <http://example.org/mdhn/herzfeld#> .

# Ontology Definition
mdhn:ArchivalOntology a owl:Ontology ;
    dct:title "Archival Ontology"@en ;
    dct:description "An ontology for archival series, subseries, and resources based on a provided JSON model, compatible with SKOS and schema.org."@en .




mdhn:IIIFManifest a owl:DatatypeProperty .

mdhn:controlAccess a owl:ObjectProperty .

mdhn:hasDigitalImage a owl:DatatypeProperty .



mdhn:hasResource a owl:ObjectProperty ;
    rdfs:label "has resource"@en ;
    rdfs:domain mdhn:Subseries ;
    rdfs:range mdhn:Resource ;
    rdfs:subPropertyOf schema:hasPart ;
    owl:inverseOf mdhn:isPartOfSubseries .    

mdhn:hasSubseries a owl:ObjectProperty ;
    rdfs:label "has subseries"@en ;
    rdfs:domain mdhn:Series ;
    rdfs:range mdhn:Subseries ;
    rdfs:subPropertyOf schema:hasPart ;
    owl:inverseOf mdhn:isPartOfSeries .
# Classes
mdhn:Series a owl:Class ;
    rdfs:label "Series"@en ;
    rdfs:comment "A collection of archival materials grouped together."@en ;
    rdfs:subClassOf schema:Collection .

mdhn:Subseries a owl:Class ;
    rdfs:label "Subseries"@en ;
    rdfs:comment "A subdivision of a series, containing related archival materials."@en ;
    rdfs:subClassOf schema:Collection .

mdhn:SubjectHeaderSource a owl:Class ;
    rdfs:label "SubjectHeaderSource"@en ;
    rdfs:comment "Top level calss for subject headings"@en .    

mdhn:ControlAccessTerm a owl:Class ;
    rdfs:label "control access"@en ;
    rdfs:comment "A subdivision of a series, containing related archival materials."@en ;
    rdfs:subClassOf mdhn:SubjectHeaderSource.   

mdhn:Resource a owl:Class ;
    rdfs:label "Resource"@en ;
    rdfs:comment "An individual archival item or file within a subseries."@en ;
    rdfs:subClassOf schema:CreativeWork .

mdhn:Note a owl:Class ;
    rdfs:label "Note"@en ;
    rdfs:comment "A structured textual note derived from arrangement or scopecontent blocks."@en ;
    rdfs:subClassOf schema:CreativeWork .


mdhn:IIIFManifest a owl:Class ;
    rdfs:label "IIIF Manifest"@en ;
    rdfs:comment "A IIIF manifest describing the available views of a digital object."@en ;
    rdfs:subClassOf schema:CreativeWork .

# Properties


mdhn:isPartOfSeries a owl:ObjectProperty ;
    rdfs:label "is part of series"@en ;
    rdfs:domain mdhn:Subseries ;
    rdfs:range mdhn:Series ;
    rdfs:subPropertyOf schema:isPartOf .



mdhn:isPartOfSubseries a owl:ObjectProperty ;
    rdfs:label "is part of subseries"@en ;
    rdfs:domain mdhn:Resource ;
    rdfs:range mdhn:Subseries ;
    rdfs:subPropertyOf schema:isPartOf .

mdhn:unitid a owl:DatatypeProperty ;
    rdfs:label "unit identifier"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf (mdhn:Series mdhn:Subseries mdhn:Resource) ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf dct:identifier .

mdhn:scopecontent a owl:DatatypeProperty ;
    rdfs:label "scope and content"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf (mdhn:Subseries mdhn:Resource) ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:description .

mdhn:unitdate a owl:DatatypeProperty ;
    rdfs:label "unit date"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf (mdhn:Subseries mdhn:Resource) ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:temporalCoverage .

mdhn:physdesc a owl:DatatypeProperty ;
    rdfs:label "physical description"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf (mdhn:Subseries mdhn:Resource) ] ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf schema:physicalCondition .

mdhn:hasDigitalImage a owl:DatatypeProperty ;
    rdfs:label "has digital image"@en ;
    rdfs:domain mdhn:Resource ;
    rdfs:range xsd:boolean .



mdhn:hasManifest a owl:ObjectProperty ;
    rdfs:label "has IIIF manifest"@en ;
    rdfs:domain mdhn:Resource ;
    rdfs:range mdhn:IIIFManifest ;
    rdfs:subPropertyOf schema:subjectOf .

mdhn:hasControlAccessTerm a owl:ObjectProperty ;
    rdfs:label "has control access term"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf (mdhn:Series mdhn:Subseries mdhn:Resource) ] ;
    rdfs:range skos:Concept ;
    rdfs:subPropertyOf schema:about ;
    owl:equivalentProperty mdhn:controlAccess .

mdhn:hasNote a owl:ObjectProperty ;
    rdfs:label "has note"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf (mdhn:Series mdhn:Subseries mdhn:Resource) ] ;
    rdfs:range mdhn:Note ;
    rdfs:subPropertyOf schema:subjectOf .

mdhn:noteHeading a owl:DatatypeProperty ;
    rdfs:label "note heading"@en ;
    rdfs:domain mdhn:Note ;
    rdfs:range xsd:string .

mdhn:noteText a owl:DatatypeProperty ;
    rdfs:label "note text"@en ;
    rdfs:domain mdhn:Note ;
    rdfs:range xsd:string .

mdhn:noteType a owl:DatatypeProperty ;
    rdfs:label "note type"@en ;
    rdfs:domain mdhn:Note ;
    rdfs:range xsd:string .

mdhn:controlAccess a owl:ObjectProperty ;
    rdfs:label "control access"@en ;
    rdfs:domain [ a owl:Class ; owl:unionOf (mdhn:Series mdhn:Subseries mdhn:Resource) ] ;
    rdfs:range skos:Concept ;
    rdfs:subPropertyOf schema:about .

mdhn:seriesType a owl:ObjectProperty ;
    rdfs:label "series type"@en ;
    rdfs:domain mdhn:Series ;
    rdfs:range skos:Concept ;
    rdfs:subPropertyOf schema:additionalType ;
    owl:inverseOf mdhn:isTypeOfSeries .

mdhn:isTypeOfSeries a owl:ObjectProperty ;
    rdfs:label "is type of series"@en ;
    rdfs:domain skos:Concept ;
    rdfs:range mdhn:Series .    

# SKOS Concept Scheme for Control Access
mdhn:ControlAccessScheme a skos:ConceptScheme ;
    skos:prefLabel "Archival Control Access Terms"@en .

# Example Instances
mdhn:ref6807 a mdhn:Series ;
    schema:name "Sketchbooks"@en ;
    mdhn:hasSubseries mdhn:ref6808 .

mdhn:ref6808 a mdhn:Subseries ;
    schema:name "Ernst Herzfeld's Sketchbooks"@en ;
    mdhn:unitid "2" ;
    mdhn:scopecontent "The sketchbooks of Ernst Herzfeld (1879-1948)..."@en ;
    mdhn:controlAccess mdhn:Taq-e-Bostan, mdhn:Sketchbooks-Genre ;
    mdhn:isPartOfSeries mdhn:ref6807 ;
    mdhn:hasResource mdhn:ref6809, mdhn:ref6810 .

mdhn:ref6809 a mdhn:Resource ;
    schema:name "SK-I Persien"@en ;
    mdhn:unitid "FSA A.06 02.01.01" ;
    mdhn:hasDigitalImage false ;
    mdhn:controlAccess mdhn:Persepolis ;
    schema:url <https://ids.si.edu/ids/deliveryService?id=FS-FSA_A.06_02.01.01> ;
    schema:description "Excavation of Persepolis (Iran): Sketchbook"@en ;
    mdhn:isPartOfSubseries mdhn:ref6808 .

mdhn:ref6810 a mdhn:Resource ;
    schema:name "SK-II Persien"@en ;
    mdhn:unitid "FSA A.06 02.01.02" ;
    mdhn:hasDigitalImage true ;
    mdhn:controlAccess mdhn:Persepolis ;
    schema:url <https://ids.si.edu/ids/deliveryService?id=FS-FSA_A.06_02.01.02> ;
    schema:description "Excavation of Persepolis (Iran): Sketch"@en ;
    mdhn:isPartOfSubseries mdhn:ref6808 .

# SKOS Concepts for Control Access
mdhn:Taq-e-Bostan a skos:Concept ;
    skos:prefLabel "Taq-e Bostan Site (Iran)"@en ;
    skos:inScheme mdhn:ControlAccessScheme ;
    skos:notation "lcsh" ;
    schema:additionalType "geographic" .

mdhn:Sketchbooks-Genre a skos:Concept ;
    skos:prefLabel "Sketchbooks"@en ;
    skos:inScheme mdhn:ControlAccessScheme ;
    skos:notation "aat" ;
    skos:exactMatch <http://vocab.getty.edu/aat/300027354> ;
    schema:additionalType "genre_form" .

mdhn:Persepolis a skos:Concept ;
    skos:prefLabel "Persepolis (Iran)"@en ;
    skos:inScheme mdhn:ControlAccessScheme ;
    skos:notation "lcsh" ;
    schema:additionalType "geographic" .

# Series Type Concepts
mdhn:TravelJournals a skos:Concept ;
    skos:prefLabel "Travel Journals"@en ;
    skos:inScheme mdhn:SeriesTypeScheme .

mdhn:Sketchbooks a skos:Concept ;
    skos:prefLabel "Sketchbooks"@en ;
    skos:inScheme mdhn:SeriesTypeScheme .

mdhn:Notebooks a skos:Concept ;
    skos:prefLabel "Notebooks"@en ;
    skos:inScheme mdhn:SeriesTypeScheme .

mdhn:PhotographicFiles a skos:Concept ;
    skos:prefLabel "Photographic Files"@en ;
    skos:inScheme mdhn:SeriesTypeScheme .

mdhn:DrawingsAndMaps a skos:Concept ;
    skos:prefLabel "Drawings and Maps"@en ;
    skos:inScheme mdhn:SeriesTypeScheme .

mdhn:Squeezes a skos:Concept ;
    skos:prefLabel "Squeezes"@en ;
    skos:inScheme mdhn:SeriesTypeScheme .

mdhn:SamarraExpedition a skos:Concept ;
    skos:prefLabel "Samarra Expedition"@en ;
    skos:inScheme mdhn:SeriesTypeScheme .    

mdhn:ref6806 a mdhn:Series ;
    schema:name "Travel Journals"@en ;
    mdhn:seriesType mdhn:TravelJournals .

mdhn:ref6807 a mdhn:Series ;
    schema:name "Sketchbooks"@en ;
    mdhn:seriesType mdhn:Sketchbooks ;
    mdhn:hasSubseries mdhn:ref6808 .    